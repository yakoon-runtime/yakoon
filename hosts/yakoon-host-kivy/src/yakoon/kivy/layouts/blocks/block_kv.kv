<KvWidget>:
    orientation: "vertical"
    size_hint_x: 1
    size_hint_y: None
    height: self.minimum_height
    spacing: dp(6)

<KvItemWidget>:
    orientation: "vertical"
    size_hint_x: 1
    size_hint_y: None
    height: self.minimum_height
    spacing: dp(2)

    BoxLayout:
        orientation: "horizontal"
        size_hint_y: None
        height: self.minimum_height

        Label:
            id: key_label
            size_hint_x: None
            size_hint_y: None
            text_size: self.width, None
            height: max(self.texture_size[1] + dp(6), dp(18))
            halign: "left"
            valign: "top"
            on_text: self.texture_update()
            on_width: self.texture_update()

        StreamLabel:
            id: value_label
            size_hint_x: 1
            size_hint_y: None
            text_size: self.width, None
            height: max(self.texture_size[1] + dp(6), dp(18))
            halign: "left"
            valign: "top"
            on_text: self.texture_update()
            on_width: self.texture_update()

    BoxLayout:
        id: body
        orientation: "vertical"
        size_hint_y: None
        height: self.minimum_height
        padding: dp(18), 0, 0, 0
        spacing: dp(2)