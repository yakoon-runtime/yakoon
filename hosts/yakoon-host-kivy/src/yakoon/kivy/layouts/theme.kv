#:kivy 2.2.0
#:import dp kivy.metrics.dp
#:import theme yakoon.kivy.themes.active.active_theme


<YkPanel@BoxLayout>:
    padding: dp(theme.pad)
    canvas.before:
        Color:
            rgba: theme.surface_input
        Rectangle:
            pos: self.pos
            size: self.size
            #radius: [dp(theme.radius)]
        Color:
            rgba: theme.border
        Line:
            rounded_rectangle: (self.x, self.y, self.width, self.height, dp(theme.radius))
            width: 1


<YkPrompt@TextInput>:
    multiline: False
    padding: dp(theme.pad_sm), dp(theme.pad_sm + 2), dp(theme.pad_sm), dp(theme.pad_sm - 2)
    foreground_color: theme.text
    background_normal: ""
    background_active: ""
    background_color: theme.surface
    cursor_color: theme.accent
    selection_color: [theme.accent[0], theme.accent[1], theme.accent[2], 0.25]
    hint_text_color: theme.muted
    font_name: theme.font_mono


<YkInputSurface@BoxLayout>:
    padding: dp(theme.pad_sm)
    size_hint_y: 1

    canvas.before:
        Color:
            rgba: theme.surface_input
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(30)]
        Color:
            #rgba: theme.border
            rgba: 0.75, 0.75, 0.75, 1
        Line:
            rounded_rectangle: (self.x, self.y, self.width, self.height, dp(30))
            width: 0.5


<YkIconButton@ButtonBehavior+Label>:
    # public props
    disabled: False

    size_hint: None, None
    width: dp(40)
    height: dp(40)
    font_name: theme.font_mono
    font_size: "18sp"
    color: theme.text
    halign: "center"
    valign: "middle"
    text_size: self.size

    canvas.before:
        Color:
            rgba: theme.surface if self.state == "normal" else [theme.surface[0]+0.05, theme.surface[1]+0.05, theme.surface[2]+0.05, 1]
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(theme.radius)]
        Color:
            rgba: theme.border
        Line:
            rounded_rectangle: (self.x, self.y, self.width, self.height, dp(theme.radius))
            width: 1


<YkPrimaryButton@ButtonBehavior+Label>:
    size_hint: None, None
    width: dp(180)          # default, kann überschrieben werden
    height: dp(44)
    padding: dp(16), 0
    #width: self.texture_size[0] + dp(32)

    font_name: theme.font_mono
    font_size: "14sp"
    color: theme.surface_input
    halign: "center"
    valign: "middle"
    text_size: self.size

    canvas.before:
        Color:
            rgba: theme.accent if self.state == "normal" else [theme.accent[0]*0.9, theme.accent[1]*0.9, theme.accent[2]*0.9, 1]
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(theme.radius)]
