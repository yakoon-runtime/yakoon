#:import dp kivy.metrics.dp
#:import theme yakoon.kivy.themes.active.active_theme
#:import NoTransition kivy.uix.screenmanager.NoTransition

<AppRootPage>:
    orientation: "vertical"
    #font_size: "22sp"
    canvas.before:
        Color:
            rgba: theme.surface_input
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(theme.radius)]
    
    # --- Topbar ---
    BoxLayout:
        id: topbar
        size_hint_y: None
        height: dp(44)
        padding: dp(theme.pad_sm), 0
        spacing: dp(8)

        canvas.before:
            Color:
                rgba: theme.surface
            Rectangle:
                pos: self.pos
                size: self.size
            Color:
                rgba: theme.border
            Line:
                points: self.x, self.y, self.right, self.y
                width: 1

        # left button (40)
        YkIconButton:
            id: btn_first
            size_hint_x: None
            width: dp(40)
            font_name: "Icons"
            text: "\ue9e2"
            on_release: root.toggle_sidebar()

        # left button (40)
        YkIconButton:
            id: btn_left
            size_hint_x: None
            width: dp(40)
            font_name: "Icons"
            text: "\uf710"   # add
            on_release: root.on_new_tab()

        TabBarScroll:
            id: tabs_scroll
            do_scroll_y: False
            do_scroll_x: True
            bar_width: 0

            TabBar:
                id: tabbar
                orientation: "horizontal"
                size_hint_x: None
                width: self.minimum_width
                height: dp(40)

        # right buttons
        YkIconButton:
            id: btn_right1
            size_hint_x: None
            width: dp(40)
            font_name: "Icons"
            text: "\ue5c3"
            on_release: root.on_right_action_1()

        YkIconButton:
            id: btn_right2
            size_hint_x: None
            width: dp(40)
            font_name: "Icons"
            text: "\ue5d2"
            on_release: root.on_right_action_2()

    # --- Body: sidebar + content ---
    BoxLayout:
        orientation: "horizontal"
        size_hint_y: 1

        BoxLayout:
            id: sidebar
            size_hint_x: None
            #width: dp(220)
            width: root.sidebar_width

        BoxLayout:
            id: content
            orientation: "vertical"
            padding: 0, 0
            size_hint_y: 1

            ScreenManager:
                id: sm
                transition: NoTransition()

                Screen:
                    name: "tabs"
                    TabViewPage:
                        id: tabs_page

                Screen:
                    name: "overview"
                    TabOverviewPage:
                        id: overview_page

