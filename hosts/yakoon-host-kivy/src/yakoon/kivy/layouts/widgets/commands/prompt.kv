#:import dp kivy.metrics.dp
#:import theme yakoon.kivy.themes.active.active_theme

<CommandPromptBar>:
    size_hint_x: 1
    size_hint_y: None
    padding: dp(12), dp(10), dp(12), dp(0)

    # Gesamthöhe = Input + (optional) Assistant + Padding
    height: chrome_inner.minimum_height + dp(10)

    YkInputSurface:
        id: chrome
        size_hint_x: 1
        size_hint_y: None
        height: chrome_inner.minimum_height + dp(10)

        BoxLayout:
            id: chrome_inner
            orientation: "vertical"
            spacing: dp(0) # button und shell text tiefer 
            padding: dp(10), dp(8)
            size_hint_y: None
            height: self.minimum_height

            # ─────────────────────────────────────────────
            # 1) INPUT ROW
            # ─────────────────────────────────────────────
            BoxLayout:
                id: input_row
                orientation: "horizontal"
                spacing: dp(8)
                size_hint_y: None
                height: max(dp(36), input.minimum_height)

                Label:
                    id: prefix
                    text: root.prefix
                    size_hint_x: None
                    width: self.texture_size[0]
                    color: theme.muted
                    opacity: 0.6 if root.locked else 1.0
                    font_name: theme.font_mono
                    valign: "middle"
                    text_size: None, self.height

                YkPrompt:
                    id: input
                    multiline: True
                    size_hint_x: 1
                    size_hint_y: None
                    height: max(dp(36), self.minimum_height)
                    hint_text: ""
                    password: root.secret
                    background_color: 0,0,0,0
                    disabled: root.locked

                AnchorLayout:
                    size_hint_x: None
                    width: dp(40)
                    anchor_x: "center"
                    anchor_y: "center"

                    Button:
                        id: submit_btn
                        text: "\ue986"
                        font_name: "Icons"
                        font_size: dp(18)
                        size_hint: None, None
                        size: dp(36), dp(36)
                        disabled: root.locked
                        background_normal: ""
                        background_down: ""
                        background_color: 0,0,0,0
                        color: 1,1,1,1
                        on_release: root._submit_internal()

                        canvas.before:
                            Color:
                                rgba: (0.25, 0.25, 0.25, 1) if self.disabled else ((0.2, 0.2, 0.2, 1) if self.state == "down" else (0, 0, 0, 1))
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [self.height/2]

            # ─────────────────────────────────────────────
            # 2) ASSIST ROW (same card, appears below input)
            # ─────────────────────────────────────────────
            BoxLayout:
                id: assist_row
                orientation: "horizontal"
                spacing: dp(6)
                size_hint_y: None

                # nimmt nur Platz, wenn assist_text da ist
                height: 0 if not root.assist_text else self.minimum_height
                opacity: 0 if not root.assist_text else 1

                # optional: eine feine Trennlinie innerhalb derselben Card
                canvas.before:
                    Color:
                        rgba: (1, 1, 1, 0.06) if root.assist_text else (0, 0, 0, 0)
                    Rectangle:
                        pos: self.x, self.top - dp(1)
                        size: self.width, dp(1)

                Label:
                    size_hint_x: None
                    width: dp(22)
                    font_name: "Icons"
                    text: {"question":"\uf59b", "warning":"\uf071", "error":"\uf06a"}.get(root.assist_state, "")
                    color: theme.text
                    valign: "top"
                    halign: "center"
                    text_size: self.size

                    canvas.before:
                        Color:
                            rgba: {"error": theme.error, "warning": theme.warning, "question": theme.accent}.get(root.assist_state, (0,0,0,0))
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(6)]

                Label:
                    text: root.assist_text
                    size_hint_x: 1
                    size_hint_y: None
                    height: 0 if not root.assist_text else self.texture_size[1]
                    color: theme.muted
                    font_name: theme.font_mono
                    halign: "left"
                    valign: "middle"
                    text_size: self.width, None