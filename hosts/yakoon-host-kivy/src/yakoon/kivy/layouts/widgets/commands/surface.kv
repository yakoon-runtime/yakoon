#:import dp kivy.metrics.dp
#:import theme yakoon.kivy.themes.active.active_theme

<CommandSurface>:
    orientation: "vertical"
    spacing: dp(theme.pad_sm)
    canvas.before:
        Color:
            rgba: theme.bg
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(theme.radius)]

    CommandPromptBar:
        id: prompt
        hint: "shell$ "
        height: dp(44)
        size_hint_y: None
        on_submit: root.submit(args[1])

    YkPanel:
        RecycleView:
            id: messages
            key_viewclass: "viewclass"
            do_scroll_x: False
            scroll_type: ['bars', 'content']
            bar_width: dp(6)

            RecycleBoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(8)
                padding: dp(theme.pad), dp(theme.pad)

                # required for variable-height items
                #default_size: None, dp(40)
                default_size_hint: 1, None

                key_size: "size"
                key_size_hint: "size_hint"