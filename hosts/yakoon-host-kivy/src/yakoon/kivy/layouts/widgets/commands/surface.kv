#:import dp kivy.metrics.dp
#:import theme yakoon.kivy.themes.active.active_theme

<CommandSurface>:
    orientation: "vertical"
    spacing: dp(theme.pad_sm)

    CommandPromptBar:
        id: prompt
        hint: "shell$ "
        height: dp(44)
        size_hint_y: None
        on_submit: root.submit(args[1])

    YkPanel:

        ScrollView:
            id: scroll
            do_scroll_x: False
            scroll_type: ['bars', 'content']
            bar_width: dp(6)

            BoxLayout:
                id: stack
                orientation: "vertical"
                size_hint_y: None
                
                size_hint_x: 1
                width: scroll.width 

                height: self.minimum_height
                spacing: dp(8)
                padding: dp(theme.pad), dp(theme.pad)
