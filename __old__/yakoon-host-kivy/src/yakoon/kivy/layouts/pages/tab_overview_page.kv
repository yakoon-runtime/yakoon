#:import dp kivy.metrics.dp
#:import theme yakoon.kivy.themes.active.active_theme


<TabOverviewPage>:
    orientation: "vertical"
    padding: dp(theme.pad)
    spacing: dp(theme.pad)
    size_hint_y: 1
    canvas.before:
        Color:
            rgba: theme.bg
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(theme.radius)]

    BoxLayout:  # -- Header
        size_hint_y: None
        height: dp(24)
        padding: 0, 0

        #Widget:

        Label:
            text: f"{root.tab_count} Tabs"
            color: theme.text
            font_name: theme.font_mono
            halign: "center"
            valign: "middle"
            text_size: self.size

        #Widget:

    ScrollView: # -- Scroller
        size_hint_y: 1
        do_scroll_x: False

        GridLayout: # -- cards are here...
            id: grid
            cols: 2
            spacing: dp(theme.pad)
            size_hint_y: None
            height: self.minimum_height

    # Footer fix und immer sichtbar
    BoxLayout:

        size_hint_y: None
        height: dp(64)
        padding: 0, dp(theme.pad_sm)

        AnchorLayout:
            anchor_x: "center"
            anchor_y: "center"

            YkPrimaryButton:
                text: "New Tab"
                size_hint_x: None
                width: dp(180)
                on_release: root.on_new_tab()
