#:kivy 2.2.0
#:import theme yakoon.kivy.themes.active.active_theme


<HeaderBlockWidget>:
    orientation: "vertical"
    size_hint_y: None
    spacing: dp(0)
    padding: dp(0), dp(0)

    Label:
        id: role_label
        size_hint_y: None
        height: self.texture_size[1] if self.text else 0
        color: theme.text
        text: ""
        bold: True
        halign: "left"
        valign: "middle"
        text_size: self.width, None

    Label:
        id: title_label
        size_hint_y: None
        height: self.texture_size[1] if self.text else 0
        color: theme.text
        text: ""
        bold: True
        halign: "left"
        valign: "middle"
        text_size: self.width, None

    Label:
        id: subtitle_label
        size_hint_y: None
        height: self.texture_size[1] if self.text else 0
        color: theme.text
        text: ""
        halign: "left"
        valign: "middle"
        text_size: self.width, None