#:import dp kivy.metrics.dp
#:import theme yakoon.kivy.themes.active.active_theme

<CommandSurface>:
    orientation: "vertical"
    spacing: 10

    canvas.before:
        Color:
            rgba: theme.surface_input
        Rectangle:
            pos: self.pos
            size: self.size
            #radius: [dp(theme.radius)]

    # ─────────────────────────────
    # Promptbar OBEN (wächst nach unten, weil height dynamisch aus prompt.kv kommt)
    # ─────────────────────────────
    CommandPromptBar:
        id: prompt
        hint: "shell$ "
        size_hint_x: 1
        size_hint_y: None
        on_submit: root.submit(args[1])

    # ─────────────────────────────
    # STATUS LABEL (neu)
    # ─────────────────────────────
    Label:
        id: status
        size_hint_y: None
        height: dp(22) if root.busy else 0
        opacity: 1 if root.busy else 0
        text: "Running…" if root.busy else ""
        color: 0.5, 0.5, 0.5, 1
        font_size: "12sp"
        halign: "left"
        valign: "middle"
        text_size: self.width, None
        padding: dp(16), 0

    # ─────────────────────────────
    # Content darunter: nimmt den Rest
    # ─────────────────────────────
    YkPanel:
        size_hint_y: 1
        padding: dp(12), dp(12)

        RecycleView:
            id: messages
            key_viewclass: "viewclass"
            do_scroll_x: False
            scroll_type: ['bars', 'content']
            bar_width: dp(6)

            RecycleBoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(8)
                #padding: dp(theme.pad), dp(theme.pad)
                padding: dp(12), dp(theme.pad)  ## content weiter nach links

                default_size_hint: 1, None
                key_size: "size"
                key_size_hint: "size_hint"