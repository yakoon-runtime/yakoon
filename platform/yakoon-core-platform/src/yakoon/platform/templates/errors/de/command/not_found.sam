<text>
  Befehl "<strong>{{ state.command }}</strong>" wurde nicht gefunden.
</text>

{% if state.suggestions %}

  {% if state.suggestions|length == 1 %}

    <text>
      Meintest du "<cmd command="{{ state.suggestions[0] }}">
        {{ state.suggestions[0] }}
      </cmd>"?
    </text>

  {% else %}

    <text>Meintest du:</text>

    <list>
      {% for item in state.suggestions %}
        <item>
          <cmd command="{{ item }}">
            {{ item }}
          </cmd>
        </item>
      {% endfor %}
    </list>

  {% endif %}

{% endif %}