<text>Verwendung:</text>

<list>
{% for usage in state.usages %}

  <item>
    
    <cmd command="...">
        {{ usage.key }}

        {% if usage.action %}
           <space/> {{ usage.action }}
        {% endif %}

        {% for arg in usage.args %}
          <space/> <arg>{{ arg }}</arg>
        {% endfor %}

        {% for opt in usage.options %}
           <space/> --{{ opt }} 
           <space/> <arg>{{ opt }}</arg>
        {% endfor %}
        
    </cmd>

  </item>

{% endfor %}
</list>