{
    "version": "0.2.0",
    "configurations": [
    

        {
            "name": "Yakoon: Run Console",
            "type": "debugpy",
            "request": "launch",
            "module": "yakoon.console.app",
            "console": "integratedTerminal",
            "env": {
                 "DEV_MODE": "true"
            },
        },

        {
            "name": "Yakoon: Run Kivy",
            "type": "debugpy",
            "request": "launch",
            "module": "yakoon.kivy.app",
            "console": "integratedTerminal",
            "env": {
                 "DEV_MODE": "true"
            },
        },


        {
            "name": "Yakoon: Run Telnet",
            "type": "debugpy",
            "request": "launch",
            "module": "yakoon.saas.bootstrap.apps.telnet.run",
            "console": "integratedTerminal",
            "env": {
                 "DEV_MODE": "true"
            },
        },

        {
            "name": "Yakoon: Run WebAPI",
            "type": "debugpy",
            "request": "launch",
            "module": "yakoon.saas.bootstrap.apps.webapi.run",
            "console": "integratedTerminal",
            "env": {
                 "DEV_MODE": "true"
            },
        },
      

    ]
}
