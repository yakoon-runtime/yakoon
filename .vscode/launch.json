{
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Yakoon: Run Migration",
            "type": "debugpy",
            "request": "launch",
            "module": "yakoon.apps.yakoon",
            "console": "integratedTerminal",
            "args": [
                "migrate", "--config=yakoon/config/backends.yaml"
            ],
            "env": {
                 "DEV_MODE": "true"
            },
        },

        {
            "name": "Yakoon: Run Console",
            "type": "debugpy",
            "request": "launch",
            "module": "yakoon.bootstrap.apps.console.run",
            "console": "integratedTerminal",
            "env": {
                 "DEV_MODE": "true"
            },
        },

        {
            "name": "Yakoon: Run Telnet",
            "type": "debugpy",
            "request": "launch",
            "module": "yakoon.bootstrap.apps.telnet.run",
            "console": "integratedTerminal",
            "env": {
                 "DEV_MODE": "true"
            },
        },

        {
            "name": "Yakoon: Run WebAPI",
            "type": "debugpy",
            "request": "launch",
            "module": "yakoon.bootstrap.apps.webapi.run",
            "console": "integratedTerminal",
            "env": {
                 "DEV_MODE": "true"
            },
        },
      

    ]
}
