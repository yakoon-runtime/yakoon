{
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Yakoon: Run Console",
            "type": "debugpy",
            "request": "launch",
            "module": "yakoon.apps.console.app",
            "console": "integratedTerminal"
        },

        {
            "name": "Yakoon: Run Telnet",
            "type": "debugpy",
            "request": "launch",
            "module": "yakoon.apps.telnet.app",
            "console": "integratedTerminal"
        },

        {
            "name": "Yakoon: Run WebAPI",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/yakoon/apps/webapi/app.py",
            "console": "integratedTerminal",
            "justMyCode": true
        },

         {
            "name": "MindDojo: Run Console",
            "type": "debugpy",
            "request": "launch",
            "module": "minddojo.app",
            "console": "integratedTerminal"
        },


    ]
}
