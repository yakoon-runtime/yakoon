{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.analysis.autoSearchPaths": true,
  "python.analysis.useLibraryCodeForTypes": true,
  "python.analysis.extraPaths": [
    // yak
    "yak",
    // runtime
    "runtime/api/src",
    "runtime/engine/src",
    "runtime/boot/src",
    "runtime/store/src",
    "runtime/transport/src",
    "runtime/llm/src",
    "sdk/python/src",
    // repos
    "repos/y5napp-system/src",
    "repos/y5napp-ident/src",
    "repos/y5napp-crm/src",
    "repos/y5napp-luma/src",
    "repos/yakoon-root/src",
    // apps
    "apps/y5napp-web/src",
    "apps/y5napp-console/src",
    "apps/y5napp-textual/src",
  ],
  "python.testing.pytestArgs": [
    "runtime/engine/tests",
    "runtime/store/tests/event",
    "runtime/store/tests/sequence",
    "repos/y5napp-luma/tests",
  ],
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "editor.formatOnSave": true,
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "ruff.enable": true,
  "ruff.organizeImports": true
}