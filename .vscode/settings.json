{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.analysis.autoSearchPaths": true,
  "python.analysis.useLibraryCodeForTypes": true,
  "python.analysis.extraPaths": [
    // runtime
    "runtime/y5ncore-base/src",
    "runtime/y5ncore-runtime/src",
    // stores (event)
    "stores/y5nstore-event/src",
    // spaces
    "spaces/y5nspace-runtime/src",
    "spaces/y5nspace-shell/src",
    "spaces/y5nspace-ident/src",
    // transports
    "transports/y5ntrans-ws/src",
    // clients
    "clients/y5ncli-console/src",
    // apps
    "apps/y5napp-web/src",
    "apps/y5napp-ssh/src",
    "apps/y5napp-console/src",
    "apps/y5napp-textual/src",
  ],
  "editor.formatOnSave": true,
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "ruff.enable": true,
  "ruff.organizeImports": true
}