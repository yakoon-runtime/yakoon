{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.analysis.autoSearchPaths": true,
  "python.analysis.useLibraryCodeForTypes": true,
  "python.analysis.extraPaths": [
    // platform
    "platform/yakoon-core-base/src",
    "platform/yakoon-core-compose/src",
    "platform/yakoon-core-platform/src",
    // apps
    "apps/yakoon-crm/src",
    "apps/yakoon-office/src",
    // exts
    "exts/yakoon-auth/src",
    "exts/yakoon-discovery/src",
    "exts/yakoon-shell/src",
    "exts/yakoon-workflow/src",
    // hosts
    "hosts/yakoon-host-console/src",
    "hosts/yakoon-host-kivy/src",
  ],
  "editor.formatOnSave": true,
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "ruff.enable": true,
  "ruff.organizeImports": true
}