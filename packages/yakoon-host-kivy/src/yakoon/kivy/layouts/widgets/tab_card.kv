<TabCard>:
    orientation: "vertical"
    size_hint: None, None
    width: dp(360)
    height: dp(220)

    canvas.before:
        Color:
            rgba: theme.surface
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(theme.radius)]
        Color:
            rgba: theme.border
        Line:
            rounded_rectangle: (self.x, self.y, self.width, self.height, dp(theme.radius))
            width: 1

    # --- Preview Area ---
    BoxLayout:
        size_hint_y: 1
        padding: dp(theme.pad_sm)

        AnchorLayout:
            size_hint: 1, 1          
            anchor_x: "right"
            anchor_y: "top"

            YkIconButton:
                text: "×"
                width: dp(34)
                height: dp(34)
                on_release: root.close()

    # --- Title ---
    BoxLayout:
        size_hint_y: None
        height: dp(40)

        Label:
            text: root.title
            color: theme.muted
            font_name: theme.font_mono
            halign: "center"
            valign: "middle"
            text_size: self.size
