#:import dp kivy.metrics.dp
#:import theme yakoon.kivy.themes.active.active_theme


<TabButton@ButtonBehavior+Label>:
    tab_id: ""
    active: False

    size_hint_x: None
    padding: dp(10), dp(6)
    width: self.texture_size[0] + dp(20)
    color: theme.text if self.active else theme.muted
    font_name: theme.font_mono

    canvas.before:
        Color:
            rgba: theme.border if self.active else [0,0,0,0]
        Line:
            rounded_rectangle: (self.x, self.y, self.width, self.height, dp(theme.radius))
            width: 1
