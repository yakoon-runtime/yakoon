#:import dp kivy.metrics.dp
#:import theme yakoon.kivy.themes.active.active_theme
#:import StencilView kivy.uix.stencilview.StencilView
 
<PromptWidget>:
    orientation: "vertical"

    StencilView:
    
        YkInputSurface:
            size_hint_y: 1

            size_hint: None, None
            pos: self.parent.pos
            size: self.parent.size

            YkPrompt:
                id: input
                multiline: True

                size_hint_y: None
                height: self.minimum_height

                background_normal: ""
                background_active: ""
                background_color: 0,0,0,0   # transparent!
                foreground_color: theme.text

                cursor_color: theme.accent

                hint_text_color: theme.muted
                hint_text: root.hint

                password: root.secret
                on_text_validate: root._submit_internal()
