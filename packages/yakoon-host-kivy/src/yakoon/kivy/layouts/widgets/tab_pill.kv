#:import dp kivy.metrics.dp
#:import theme yakoon.kivy.themes.active.active_theme


<TabPill@ButtonBehavior+Label>:
    tab_id: ""
    active: False

    #radius: self.height / 2

    size_hint: None, None
    padding: dp(12), 0

    font_name: theme.font_mono
    font_size: "14sp"
    halign: "center"
    valign: "middle"

    halign: "center"
    valign: "middle"
    padding: dp(0), dp(32)     # x, y

    text_size: None, None
    width: self.texture_size[0] + dp(24)
    height: dp(40)

    color: theme.text if self.active else theme.muted

    canvas.before:
        Color:
            rgba: theme.accent if self.active else theme.surface
        RoundedRectangle:
            pos: self.pos
            size: self.size

        Color:
            rgba: theme.accent if self.active else theme.border
