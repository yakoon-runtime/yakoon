
<br/>
Commands: <br/>

{% for c in state.nodes %}
    {% if not c.navigable %}
      <space count="2"/> <cmd command="{{ c.key }}">{{ c.key }}</cmd>
    {% endif %}
{% endfor %}

{% if state.navigables %}
  <br/><br/>
  Spaces: <br/>

  {% for c in state.navigables %}
      {% if c.navigable %}
        <space count="2"/> <cmd command="{{ c.key }}">{{ c.key }}</cmd>
      {% endif %}
  {% endfor %}

{% endif %}