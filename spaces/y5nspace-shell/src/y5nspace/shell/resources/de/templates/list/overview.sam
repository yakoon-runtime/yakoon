Commands: <br/>

{% for c in state.nodes %}
    {% if not c.navigable %}
      <space count="2"/> <cmd command="{{ c.key }}">{{ c.key }}</cmd>
    {% endif %}
{% endfor %}

{% if state.navigables %}
  <br/><br/>
  Spaces: <br/>

  {% for c in state.navigables %}
      {% if c.navigable %}
        <space count="2"/> <cmd command="{{ c.key }}">{{ c.key }}</cmd>
      {% endif %}
  {% endfor %}

{% endif %}


<table>
  <column key="name" title="Name"/>
  <column key="age" title="Age"/>
  <row>
    <cell>Stefan</cell>
    <cell>42</cell>
  </row>
  <row>
    <cell>Anna</cell>
    <cell>31</cell>
  </row>
</table>