<strong>Commands</strong>
<br/>
▷<space count="2"/>
{% for c in state.commands %}
  <cmd command="{{ c.key }}" variant="{{ c.variant }}">{{ c.key }}</cmd>
  <space count="3"/>
{% endfor %}

<br/><br/>
<strong>Spaces</strong>
<br/>
▷<space count="2"/>
{% for c in state.spaces %}
  <cmd command="{{ c.key }}" variant="{{ c.variant }}">{{ c.key }}</cmd>
  <space count="3"/>
{% endfor %}
