<text foreground="bright_black">{{ state.path }}/</text>
<br/>
<br/>
{% if state.dirs %}
{% for d in state.dirs %}
  <cmd command="{{ d.name }}" variant="local" navigable="true" resolvable="false">{{ d.name }}/</cmd>
  <space count="3"/>
{% endfor %}
<br/>
{% endif %}
{% if state.files %}
{% for f in state.files %}
  <cmd command="{{ f.name }}" variant="local" navigable="false" resolvable="true">{{ f.name }}</cmd>
  <space count="3"/>
{% endfor %}
{% endif %}
