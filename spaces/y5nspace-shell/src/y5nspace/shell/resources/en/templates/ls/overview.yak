{% if state.commands %}
<strong>Commands</strong>
<br/>
▷<space count="2"/>
{% for c in state.commands %}
  <cmd command="{{ c.key }}" variant="{{ c.variant }}">{{ c.key }}</cmd>
  <space count="3"/>
{% endfor %}

{% endif %}
{% if state.spaces %}
{% if state.commands %}
<br/><br/>
{% endif %}
<strong>Spaces</strong>
<br/>
▷<space count="2"/>
{% for c in state.spaces %}
  <cmd command="{{ c.key }}" variant="{{ c.variant }}">{{ c.key }}</cmd>
  <space count="3"/>
{% endfor %}
{% endif %}
