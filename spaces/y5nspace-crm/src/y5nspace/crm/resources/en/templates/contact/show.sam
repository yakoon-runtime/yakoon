Contact: {{ state.contact.data.name }}
{% if state.contact.data.company %}  Company: {{ state.contact.data.company }}{% endif %}
{% if state.contact.data.email %}  Email:   {{ state.contact.data.email }}{% endif %}
{% if state.contact.data.phone %}  Phone:   {{ state.contact.data.phone }}{% endif %}
{% if state.contact.data.street %}  Street:  {{ state.contact.data.street }}{% endif %}
{% if state.contact.data.zip or state.contact.data.city %}  City:    {{ state.contact.data.zip }} {{ state.contact.data.city }}{% endif %}
{% if state.contact.data.country %}  Country: {{ state.contact.data.country }}{% endif %}
{% if state.contact.data.notes %}  Notes:   {{ state.contact.data.notes }}{% endif %}
