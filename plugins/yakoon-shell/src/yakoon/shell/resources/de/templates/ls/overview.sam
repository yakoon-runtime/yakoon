{%- if state.mode == "shell" -%}

<br/>
Commands: <br/>

{% for c in state.commands %}
<space count="2"/> <cmd command="{{ c.key }}">{{ c.key }}</cmd>
{% endfor %}

<br/><br/>
Applications: <br/>

{% for a in state.apps %}
  <space count="2"/> <cmd command="use {{ a.id }}">{{ a.name }}</cmd>
{% endfor %}

{% elif state.mode == "program" %}
<br/>
Commands: <br/>
  {% for c in state.commands %}
  <space count="2"/> <cmd command="{{ c.key }}">{{ c.key }}</cmd>
  {% endfor %}
{% endif %}