{% if not state.grants %}
No grants found for permission
'{{ state.permission }}'.
{% else %}

Subjects with permission
'{{ state.permission }}':

<list>
{% for g in state.grants %}
<item>
{{ g.subject_key.id }}
[{{ g.bits }}]
{% if g.deny %}(deny){% endif %}
</item>
{% endfor %}
</list>

{% endif %}